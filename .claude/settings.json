{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "PowerShell",
      "Edit",
      "Write",
      "Read",
      "NotebookEdit"
    ]
  },
  "mcpServers": {
    "docker-mcp": {
      "command": "uv",
      "args": [
        "--directory",
        "docker-mcp",
        "run",
        "docker-mcp"
      ]
    },
    "mcp-server-docker": {
      "command": "uvx",
      "args": [
        "mcp-server-docker"
      ]
    },
    "postgres": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network",
        "php-react-postgre-claude-workspace_default",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "env": {
        "DATABASE_URI": "postgresql://postgres:postgres@postgres:5432/myapp_db"
      }
    },
    "postgres-full": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network",
        "php-react-postgre-claude-workspace_default",
        "-e",
        "DATABASE_URI=postgresql://postgres:postgres@postgres:5432/myapp_db",
        "node:20-alpine",
        "npx",
        "-y",
        "mcp-postgres-full-access",
        "postgresql://postgres:postgres@postgres:5432/myapp_db"
      ]
    },
    "rsuite": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@rsuite/mcp@latest"
      ]
    }
  }
}